rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global safety net default-deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Complaints collection authorization
    match /complaints/{complaintId} {
      // Allow any visitor to read community announcements and the district pulse ledger
      allow read: if true;

      // Allow creating reports if authenticated or fallback as anonymous guest
      allow create: if (
          (request.auth != null && request.resource.data.reportedBy == request.auth.uid) ||
          (request.auth == null && request.resource.data.reportedBy == "anonymous")
        )
        && request.resource.data.status == "pending";

      // Allow updating the complaint status (for marking resolved, etc.)
      allow update: if true;

      // Allow deletion for admin/cleaning/wiping reports
      allow delete: if true;
    }

    // 3. Resolution Verification collection authorization
    match /resolution_verification/{verificationId} {
      allow read, create, delete: if true;
    }

    // 4. AI Logs collection authorization
    match /ai_logs/{logId} {
      allow read, write: if true;
    }
  }
}
